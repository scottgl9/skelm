{
  "name": "skelm-workspace",
  "version": "0.4.5",
  "private": true,
  "description": "skelm monorepo workspace root",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "guards": "node scripts/guards/default-deny-permissions.ts && node scripts/guards/public-export-baseline.ts && node scripts/guards/gateway-only-enforcement.ts && node scripts/guards/docs-orphans.ts && node scripts/guards/dist-invariants.ts && node scripts/guards/cli-no-core-runtime.ts && node scripts/guards/backend-contract-exhaustive.ts",
    "check": "pnpm build && pnpm typecheck && pnpm lint && pnpm guards && pnpm test",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "release:dry": "DRY_RUN=1 ./scripts/publish-npm.sh",
    "release": "./scripts/publish-npm.sh",
    "release:gh:dry": "DRY_RUN=1 ./scripts/publish-gh-packages.sh",
    "release:gh": "./scripts/publish-gh-packages.sh",
    "release:gh:check": "node scripts/check-gh-visibility.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "zod": "^4.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"],
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "protobufjs@<7.5.8": "7.5.8"
    }
  }
}
