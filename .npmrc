# GitHub Packages registry
@skelm:registry=https://npm.pkg.github.com/scottgl9

# Always use HTTPS when fetching from GitHub Packages
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

# For public npm registry fallback (if needed)
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Publish to GitHub Packages by default
publishConfig.registry=https://npm.pkg.github.com/scottgl9
