{
  "name": "@skelm/integrations",
  "version": "0.3.4",
  "description": "Third-party integrations for skelm pipelines",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://github.com/scottgl9/skelm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/integrations"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "integrations", "github", "slack", "jira", "telegram"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skelm/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
