{
  "name": "@skelm/memory-system",
  "version": "0.4.8",
  "description": "First-party memory-management workflows for skelm — scheduled daily-note, summarization, archive, consolidation, promotion, pruning, and integrity audits over agentmemory + durable state",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/memory-system"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "agentmemory", "memory", "workflows", "agents"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "skelm.package.json", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@skelm/agentmemory": "workspace:*",
    "zod": "^4.4.2"
  },
  "peerDependencies": {
    "@skelm/core": "workspace:*"
  },
  "devDependencies": {
    "@skelm/core": "workspace:*",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.18"
  }
}
