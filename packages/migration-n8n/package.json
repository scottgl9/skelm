{
  "name": "@skelm/migration-n8n",
  "version": "0.1.0",
  "description": "Import n8n workflow JSON exports into reviewable skelm TypeScript workflow skeletons",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/migration-n8n"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "n8n", "migration", "workflow", "import"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "workflows", "self-test", "skelm.package.json", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@skelm/core": "workspace:*"
  },
  "devDependencies": {
    "@skelm/migration-n8n": "workspace:*",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.18"
  }
}
