{
  "name": "skelm",
  "version": "0.4.8",
  "description": "Open-source agentic workflow engine for secure, long-running workflows — author, schedule, and operate typed TypeScript pipelines that mix code, inference, and agents under default-deny permissions.",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/skelm"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": [
    "skelm",
    "workflow-engine",
    "workflow",
    "pipeline",
    "orchestration",
    "agent",
    "agentic",
    "agent-framework",
    "ai-agents",
    "ai-workflow",
    "llm",
    "llm-orchestration",
    "durable-workflow",
    "scheduler",
    "automation",
    "typescript",
    "mcp",
    "acp",
    "security",
    "permissions",
    "default-deny",
    "gateway",
    "openai",
    "anthropic",
    "claude",
    "codex",
    "opencode",
    "vercel-ai"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skelm": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@skelm/core": "workspace:*",
    "@skelm/cli": "workspace:*",
    "@skelm/scheduler": "workspace:*",
    "@skelm/integration-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.18"
  }
}
