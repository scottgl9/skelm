{
  "name": "@skelm/core",
  "version": "0.4.3",
  "description": "skelm runtime, types, and builders",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": [
    "skelm",
    "workflow",
    "pipeline",
    "agent",
    "agentic",
    "llm",
    "mcp",
    "acp",
    "orchestration",
    "typescript",
    "automation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "default": "./dist/backend.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "default": "./dist/permissions.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./skills": {
      "types": "./dist/skills.d.ts",
      "default": "./dist/skills.js"
    },
    "./system-prompt": {
      "types": "./dist/system-prompt.d.ts",
      "default": "./dist/system-prompt.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./testing/contract": {
      "types": "./dist/testing/contract.d.ts",
      "default": "./dist/testing/contract.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "prepublishOnly": "node ../../scripts/guards/dist-invariants.ts"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "better-sqlite3": "12.9.0"
  },
  "peerDependencies": {
    "vitest": "^2.1.5"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.6.3"
  }
}
