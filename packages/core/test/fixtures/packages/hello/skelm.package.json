{
  "name": "@skelm/hello",
  "version": "0.1.0",
  "description": "Minimal fixture workflow package for the package substrate tests.",
  "license": "MIT",
  "skelm": {
    "apiVersion": 1,
    "requiredSkelmVersion": ">=0.4.0",
    "workflows": [
      {
