{
  "name": "@skelm/vercel-ai",
  "version": "0.4.8",
  "description": "Vercel AI SDK backend for skelm — bind a Vercel AI LanguageModel as a skelm agent and inference backend with permission-enforced tool use and streaming",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/vercel-ai"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "vercel-ai", "ai-sdk", "agent", "backend"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "ai": ">=5.0.0",
    "@skelm/agentmemory": "workspace:*",
    "@skelm/core": "workspace:*"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@skelm/agentmemory": "workspace:*",
    "@skelm/core": "workspace:*",
    "@types/node": "^20.10.0",
    "ai": "^6.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0",
    "zod": "^4.4.2"
  }
}
