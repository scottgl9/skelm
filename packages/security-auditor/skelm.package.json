{
  "name": "@skelm/security-auditor",
  "version": "0.4.8",
  "description": "Static security audit for skelm workflows and packages.",
  "license": "MIT",
  "skelm": {
    "apiVersion": 1,
    "requiredSkelmVersion": ">=0.4.0",
    "workflows": [
      {
        "id": "default",
        "entry": "workflows/audit.workflow.ts",
        "kind": "pipeline",
        "description": "Audit a loaded workflow for security issues without executing it."
      }
    ],
    "config": {
      "failOn": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "default": "high",
        "description": "Lowest finding severity that fails the audit."
      },
      "rules": {
        "type": "object",
        "description": "Per-rule { enabled?, severity? } overrides keyed by rule id.",
        "properties": {
          "fs-write-broad": { "type": "object" },
          "network-egress-broad": { "type": "object" },
          "unrestricted-grant": { "type": "object" },
          "secret-value-in-source": { "type": "object" },
          "risky-executable-profile": { "type": "object" },
          "missing-approval-privileged": { "type": "object" },
          "manifest-permission-drift": { "type": "object" },
          "unverified-webhook-trigger": { "type": "object" }
        }
      }
    },
    "selfTest": {
      "entry": "workflows/audit.selftest.ts"
    }
  }
}
