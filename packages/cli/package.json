{
  "name": "@skelm/cli",
  "version": "0.4.6",
  "description": "skelm CLI primitives. End users install the meta-package `skelm`, which depends on this and exposes the `skelm` bin. This package is the programmatic entry point for tooling that wants to drive the CLI directly.",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "cli", "workflow", "pipeline", "agent"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "assets", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "node ../../scripts/guards/dist-invariants.ts"
  },
  "dependencies": {
    "@skelm/agent": "workspace:*",
    "@skelm/codex": "workspace:*",
    "@skelm/core": "workspace:*",
    "@skelm/opencode": "workspace:*",
    "@skelm/pi": "workspace:*",
    "@skelm/gateway": "workspace:*",
    "commander": "^15.0.0",
    "dotenv": "^16.4.5",
    "eventsource-parser": "^3.1.0",
    "get-port": "^7.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
