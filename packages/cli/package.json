{
  "name": "@skelm/cli",
  "version": "0.2.0",
  "description": "skelm command line interface",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://github.com/scottgl9/skelm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": [
    "skelm",
    "cli",
    "workflow",
    "pipeline",
    "agent"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skelm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/scottgl9",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skelm/core": "workspace:*",
    "@skelm/server": "workspace:*",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
