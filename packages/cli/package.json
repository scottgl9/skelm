{
  "name": "@skelm/cli",
  "version": "0.1.0",
  "description": "skelm command line interface",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skelm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skelm/core": "workspace:*",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
