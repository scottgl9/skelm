:root {
  color-scheme: light;
  --bg: #f4f6f8;
  --rail: #0c1d2f;
  --rail-2: #12283d;
  --panel: #ffffff;
  --panel-soft: #f9fafb;
  --line: #dce2e8;
  --line-strong: #c8d1dc;
  --text: #17202a;
  --muted: #657386;
  --muted-2: #8793a3;
  --accent: #edac30;
  --accent-ink: #2b1a00;
  --green: #14784f;
  --red: #b83934;
  --amber: #a96600;
  --blue: #256aa8;
  --shadow: 0 14px 34px rgba(15, 30, 45, 0.08);
}

* {
  box-sizing: border-box;
}

html,
body {
  min-height: 100%;
}

body {
  margin: 0;
  font: 14px / 1.45 Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
    sans-serif;
  color: var(--text);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(244, 246, 248, 0.98)),
    var(--bg);
}

button,
input,
textarea {
  font: inherit;
}

button {
  min-height: 34px;
  border: 1px solid var(--line-strong);
  background: linear-gradient(#fff, #f7f9fb);
  color: var(--text);
  border-radius: 7px;
  padding: 7px 11px;
  cursor: pointer;
  font-weight: 650;
  transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
}

button:hover:not(:disabled) {
  border-color: #aeb9c7;
  box-shadow: 0 1px 0 rgba(12, 29, 47, 0.08);
}

button:active:not(:disabled) {
  transform: translateY(1px);
}

button.primary {
  background: linear-gradient(180deg, #f4bf55, var(--accent));
  border-color: #d6951e;
  color: var(--accent-ink);
}

button.danger {
  background: #fff;
  border-color: #efc4c1;
  color: var(--red);
}

button:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

a {
  color: var(--blue);
  font-weight: 650;
  text-decoration: none;
}

a:hover {
  text-decoration: underline;
}

#app {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 260px minmax(0, 1fr);
}

.side {
  position: sticky;
  top: 0;
  height: 100vh;
  padding: 18px 14px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0)),
    var(--rail);
  color: #f6f8fb;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 4px 5px 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.mark {
  width: 38px;
  height: 38px;
  display: block;
  border-radius: 9px;
  box-shadow: 0 8px 22px rgba(0, 0, 0, 0.2);
}

.brand strong,
.brand span {
  display: block;
}

.brand strong {
  font-size: 17px;
  line-height: 1.15;
}

.brand span {
  color: #aab7c7;
  font-size: 12px;
}

nav {
  display: grid;
  gap: 3px;
}

.nav-btn {
  width: 100%;
  text-align: left;
  border-color: transparent;
  background: transparent;
  color: #cbd6e4;
  padding: 8px 10px;
}

.nav-btn:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

.nav-btn.active {
  background: var(--rail-2);
  border-color: rgba(237, 172, 48, 0.55);
  color: #fff;
}

.status-strip {
  margin-top: auto;
  padding: 11px;
  border: 1px solid rgba(255, 255, 255, 0.11);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.06);
  color: #aab7c7;
  min-height: 48px;
}

.main {
  min-width: 0;
  padding: 24px;
}

.topbar {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--line);
}

.eyebrow {
  margin: 0 0 4px;
  color: var(--muted);
  text-transform: uppercase;
  font-size: 11px;
  font-weight: 750;
  letter-spacing: 0;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  font-size: 27px;
  line-height: 1.15;
  margin-bottom: 0;
}

h2 {
  font-size: 16px;
  margin-bottom: 10px;
}

h3 {
  font-size: 13px;
  margin-bottom: 8px;
  color: var(--muted);
  text-transform: uppercase;
}

.actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.notice {
  border: 1px solid #e4bf72;
  background: #fff8e8;
  color: #5d3a00;
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 14px;
}

.hidden {
  display: none;
}

.content {
  display: grid;
  gap: 14px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.panel,
.card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.panel {
  padding: 16px;
}

.card {
  padding: 14px;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: start;
  margin-bottom: 12px;
}

.section-head p {
  margin-bottom: 0;
}

.metric {
  display: grid;
  gap: 5px;
  min-height: 94px;
  border-top: 3px solid var(--accent);
}

.metric strong {
  font-size: 28px;
  line-height: 1;
}

.metric span:last-child {
  color: var(--muted);
  font-size: 12px;
}

.muted {
  color: var(--muted);
}

.table-wrap {
  overflow-x: auto;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  box-shadow: var(--shadow);
}

table {
  width: 100%;
  border-collapse: collapse;
  min-width: 720px;
}

th,
td {
  padding: 11px 12px;
  border-bottom: 1px solid var(--line);
  text-align: left;
  vertical-align: top;
}

th {
  position: sticky;
  top: 0;
  color: var(--muted);
  background: #f8fafc;
  font-size: 12px;
  font-weight: 750;
}

tbody tr {
  transition: background 120ms ease;
}

tbody tr:hover {
  background: #fbfcfd;
}

tr:last-child td {
  border-bottom: 0;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 22px;
  border-radius: 999px;
  padding: 2px 8px;
  background: #eef2f6;
  color: var(--muted);
  font-size: 12px;
  font-weight: 700;
}

.pill.ok {
  background: #e4f3eb;
  color: var(--green);
}

.pill.warn {
  background: #fff2d9;
  color: var(--amber);
}

.pill.bad {
  background: #fae6e5;
  color: var(--red);
}

.split {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(340px, 0.74fr);
  gap: 14px;
}

.split.even {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.form {
  display: grid;
  gap: 11px;
}

label {
  display: grid;
  gap: 6px;
  color: var(--muted);
  font-size: 12px;
  font-weight: 750;
}

textarea,
input {
  width: 100%;
  border: 1px solid var(--line-strong);
  border-radius: 7px;
  padding: 9px 10px;
  background: #fff;
  color: var(--text);
  outline: none;
}

textarea:focus,
input:focus {
  border-color: #c79029;
  box-shadow: 0 0 0 3px rgba(237, 172, 48, 0.16);
}

textarea {
  min-height: 118px;
  resize: vertical;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 13px;
}

.file-drop {
  border: 1px dashed var(--line-strong);
  border-radius: 8px;
  background: var(--panel-soft);
  padding: 12px;
  cursor: pointer;
}

.file-drop input {
  inline-size: 1px;
  block-size: 1px;
  opacity: 0;
  position: absolute;
  pointer-events: none;
}

.file-drop span {
  color: var(--text);
  font-size: 14px;
}

.file-drop strong {
  color: var(--muted);
  font-size: 12px;
  overflow-wrap: anywhere;
}

pre {
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  background: #f6f8fa;
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px;
  max-height: 430px;
  overflow: auto;
  color: #26313d;
}

.row-actions {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

@media (max-width: 980px) {
  #app {
    display: block;
  }

  .side {
    position: static;
    height: auto;
    border-right: 0;
  }

  nav {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .main {
    padding: 18px;
  }

  .topbar,
  .split,
  .split.even {
    display: grid;
    grid-template-columns: 1fr;
  }

  .grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 560px) {
  nav,
  .grid {
    grid-template-columns: 1fr;
  }

  h1 {
    font-size: 22px;
  }

  .main {
    padding: 14px;
  }
}
