async function loadGraph(ctx: ModuleContext, id: string): Promise<void> {
  const canvas = required<HTMLElement>('#graph-canvas', ctx.mount)
  let graph: GraphResponse
  try {
    graph = await gateway.json<GraphResponse>(`/v1/workflows/${encodeURIComponent(id)}/graph`)
  } catch (err) {
    canvas.innerHTML = `<p class="muted">Graph unavailable: ${escapeHtml(messageOf(err))}</p>`
    return
  }
  const legend = `
    <div class="graph-legend">
      <span class="pill">${escapeHtml(graph.kind ?? 'graph')}</span>
      <span class="pill code-owned">code-owned</span>
      <span class="muted">${(graph.nodes ?? []).length} top-level nodes</span>
    </div>`
  const body = (graph.nodes ?? []).map((node) => renderGraphNode(node)).join('')
  canvas.innerHTML = `${legend}<div class="graph-flow">${body || '<p class="muted">Empty graph</p>'}</div>`
}

function renderGraphNode(node: GraphNode): string {
  const codeOwned = node.codeOwned === true
  const perms = node.permissions
  const dims =
    perms && perms.dimensions && perms.dimensions.length > 0
      ? `<div class="graph-perms">${perms.dimensions
          .map((d) => `<span class="pill perm">${escapeHtml(d)}</span>`)
          .join('')}${perms.profile ? `<span class="pill">profile: ${escapeHtml(perms.profile)}</span>` : ''}</div>`
      : ''
  const children =
    node.children && node.children.length > 0
      ? `<div class="graph-children">${node.children.map((c) => renderGraphNode(c)).join('')}</div>`
      : ''
  const summary = node.summary ? `<div class="muted">${escapeHtml(node.summary)}</div>` : ''
  return `
    <div class="graph-node ${codeOwned ? 'code-owned' : ''}">
      <div class="graph-node-head">
        <span class="graph-kind">${escapeHtml(node.kind ?? 'step')}</span>
        <strong>${escapeHtml(node.label ?? node.id)}</strong>
        ${codeOwned ? '<span class="pill code-owned" title="wraps author code; not editable">code-owned</span>' : ''}
      </div>
      ${summary}
      ${dims}
      ${children}
    </div>`
}

