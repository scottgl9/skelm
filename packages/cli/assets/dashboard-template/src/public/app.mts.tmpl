async function loadRunDetail(ctx: ModuleContext, runId: string): Promise<void> {
  ctx.params.run = runId
  closeStream()
  const detail = required<HTMLElement>('#run-detail', ctx.mount)
  const [run, eventsRes, artifactsRes] = await Promise.all([
    gateway.json<Record<string, any>>(`/runs/${encodeURIComponent(runId)}`),
    gateway.maybe<{ events: GatewayEvent[] }>(`/runs/${encodeURIComponent(runId)}/events`, {
      events: [],
    }),
    gateway.maybe<{ artifacts: Array<Record<string, any>> }>(
      `/runs/${encodeURIComponent(runId)}/artifacts`,
      { artifacts: [] },
    ),
  ])
  detail.innerHTML = `
    <h2>${escapeHtml(run.runId)}</h2>
    <p><span class="pill ${statusClass(run.status)}">${escapeHtml(run.status)}</span> <span class="muted">${escapeHtml(run.pipelineId ?? run.workflowId ?? '')}</span></p>
    <div class="row-actions">
      <button id="stream-run" type="button">Stream Events</button>
      <button id="view-lineage" type="button">Lineage</button>
    </div>
    <h3>Timeline</h3>
    <div id="timeline" class="timeline">${renderTimeline(eventsRes.events ?? [])}</div>
    <h3>Artifacts</h3>
    ${artifactsList(runId, artifactsRes.artifacts ?? [])}
    <h3>Run State</h3>
    <pre>${escapeHtml(JSON.stringify(run, null, 2))}</pre>
  `
  required<HTMLButtonElement>('#stream-run', detail).addEventListener('click', () =>
    streamRun(runId),
  )
  required<HTMLButtonElement>('#view-lineage', detail).addEventListener('click', () =>
    ctx.navigate('lineage', { run: runId }),
  )
}

function renderTimeline(events: readonly GatewayEvent[]): string {
  if (events.length === 0) return '<p class="muted">No events recorded</p>'
  return events
    .map((e) => {
      const type = String(e.type ?? e.event ?? 'event')
      const label = e.stepId ?? e.toolName ?? ''
      return `
      <div class="tl-row ${timelineClass(type)}">
        <span class="tl-dot"></span>
        <div class="tl-body">
          <div class="tl-head"><strong>${escapeHtml(type)}</strong>${label ? `<span class="muted">${escapeHtml(String(label))}</span>` : ''}<span class="muted tl-time">${formatTime(e.timestamp ?? e.at)}</span></div>
          ${timelineDetail(e)}
        </div>
      </div>`
    })
    .join('')
}

function timelineDetail(e: GatewayEvent): string {
  const payload = e.data ?? e.payload ?? e.detail
  if (payload === undefined || payload === null) {
    if (e.error !== undefined)
      return `<div class="tl-detail bad">${escapeHtml(String(e.error))}</div>`
    return ''
  }
  return `<pre class="tl-detail">${escapeHtml(JSON.stringify(payload, null, 2))}</pre>`
}

function timelineClass(type: string): string {
  if (type.includes('error') || type.includes('failed') || type === 'permission.denied') return 'bad'
  if (type.includes('complete') || type.includes('completed')) return 'ok'
  if (type.includes('start') || type.includes('call')) return 'info'
  return ''
}

