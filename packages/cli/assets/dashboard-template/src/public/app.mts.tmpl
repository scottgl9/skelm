async function runWorkflow(ctx: ModuleContext): Promise<void> {
  const id = required<HTMLInputElement>('#workflow-id', ctx.mount).value.trim()
  if (!id) return ctx.setNotice('Workflow id is required')
  let input: unknown
  try {
    input = JSON.parse(required<HTMLTextAreaElement>('#workflow-input', ctx.mount).value || '{}')
  } catch {
    return ctx.setNotice('Workflow input must be JSON')
  }
  const result = await gateway.json<{ runId: string }>(
    `/pipelines/${encodeURIComponent(id)}/start`,
    { method: 'POST', body: JSON.stringify({ input }) },
  )
  ctx.navigate('runs', { run: result.runId })
}

async function uploadWorkflow(ctx: ModuleContext): Promise<void> {
  const input = required<HTMLInputElement>('#upload-file', ctx.mount)
  const file = input.files?.[0]
  if (file === undefined) return ctx.setNotice('Choose a .zip, .mts, or .ts workflow file')
  const id = required<HTMLInputElement>('#upload-id', ctx.mount).value.trim()
  const entry = required<HTMLInputElement>('#upload-entry', ctx.mount).value.trim()
  const archive = file.name.endsWith('.zip')
    ? new Uint8Array(await file.arrayBuffer())
    : await zipSingleFile(file)
  const form = new FormData()
  if (id !== '') form.set('id', id)
  if (entry !== '') form.set('entry', entry)
  form.set(
    'archive',
    new Blob([archive], { type: 'application/zip' }),
    file.name.endsWith('.zip') ? file.name : `${file.name}.zip`,
  )
  const res = await fetch('/api/v1/workflows/register', { method: 'POST', body: form })
  if (!res.ok) throw new Error(`${res.status} ${await res.text()}`)
  const body = (await res.json()) as { workflow?: { id?: string } }
  ctx.setNotice(`Workflow uploaded: ${(body.workflow?.id ?? id) || file.name}`)
  await workflowsModule.render(ctx)
}

async function zipSingleFile(file: File): Promise<Uint8Array> {
  const nameBytes = new TextEncoder().encode(file.name)
  const data = new Uint8Array(await file.arrayBuffer())
  const crc = crc32(data)
  const now = new Date()
  const time =
    ((now.getHours() & 0x1f) << 11) |
    ((now.getMinutes() & 0x3f) << 5) |
    ((now.getSeconds() / 2) & 0x1f)
  const date =
    (((now.getFullYear() - 1980) & 0x7f) << 9) |
    (((now.getMonth() + 1) & 0xf) << 5) |
    (now.getDate() & 0x1f)
  const localSize = 30 + nameBytes.length + data.length
  const centralSize = 46 + nameBytes.length
  const out = new Uint8Array(localSize + centralSize + 22)
  const view = new DataView(out.buffer)
  let offset = 0
  const writeU16 = (value: number): void => {
    view.setUint16(offset, value, true)
    offset += 2
  }
  const writeU32 = (value: number): void => {
    view.setUint32(offset, value >>> 0, true)
    offset += 4
  }
  const writeBytes = (bytes: Uint8Array): void => {
    out.set(bytes, offset)
    offset += bytes.length
  }

  writeU32(0x04034b50)
  writeU16(20)
  writeU16(0)
  writeU16(0)
  writeU16(time)
  writeU16(date)
  writeU32(crc)
  writeU32(data.length)
  writeU32(data.length)
  writeU16(nameBytes.length)
  writeU16(0)
  writeBytes(nameBytes)
  writeBytes(data)

  const centralOffset = offset
  writeU32(0x02014b50)
  writeU16(20)
  writeU16(20)
  writeU16(0)
  writeU16(0)
  writeU16(time)
  writeU16(date)
  writeU32(crc)
  writeU32(data.length)
  writeU32(data.length)
  writeU16(nameBytes.length)
  writeU16(0)
  writeU16(0)
  writeU16(0)
  writeU16(0)
  writeU32(0)
  writeU32(0)
  writeBytes(nameBytes)

  const centralLength = offset - centralOffset
  writeU32(0x06054b50)
  writeU16(0)
  writeU16(0)
  writeU16(1)
  writeU16(1)
  writeU32(centralLength)
  writeU32(centralOffset)
  writeU16(0)
  return out
}

function crc32(data: Uint8Array): number {
  let crc = 0xffffffff
  for (const byte of data) {
    crc = (crc >>> 8) ^ CRC32_TABLE[(crc ^ byte) & 0xff]
  }
  return (crc ^ 0xffffffff) >>> 0
}

const CRC32_TABLE = Array.from({ length: 256 }, (_, index) => {
  let value = index
  for (let bit = 0; bit < 8; bit += 1) {
    value = (value & 1) === 1 ? 0xedb88320 ^ (value >>> 1) : value >>> 1
  }
  return value >>> 0
})

async function loadWorkflowDetail(ctx: ModuleContext, id: string): Promise<void> {
  const detail = required<HTMLElement>('#wf-detail', ctx.mount)
  detail.innerHTML = '<p class="muted">Loading workflow</p>'
  const info = await gateway.maybe<Record<string, any> | null>(
    `/pipelines/${encodeURIComponent(id)}`,
    null,
  )
  if (info === null) {
    detail.innerHTML = `<p class="muted">No detail for ${escapeHtml(id)}</p>`
    return
  }
  const perms = collectPermissionDimensions(info)
  detail.innerHTML = `
    <h2>${escapeHtml(id)}</h2>
    <p class="muted">${escapeHtml(info.description ?? '')}</p>
    <h3>Permissions Summary</h3>
    ${permissionsSummary(perms)}
    <div class="row-actions">
      <button class="primary" data-open-graph="${escapeAttr(id)}">Open Graph</button>
    </div>
    <h3>Definition</h3>
    <pre>${escapeHtml(JSON.stringify(info, null, 2))}</pre>
  `
  required<HTMLButtonElement>('[data-open-graph]', detail).addEventListener('click', () =>
    ctx.navigate('graph', { id }),
  )
}

