// ---------------------------------------------------------------------------
// App shell
// ---------------------------------------------------------------------------

const state: AppState = {
  module: 'overview',
  params: {},
  stream: null,
  timer: null,
}

const el = {
  nav: required<HTMLElement>('#nav'),
  title: required<HTMLElement>('#page-title'),
  content: required<HTMLElement>('#content'),
  notice: required<HTMLElement>('#notice'),
  status: required<HTMLElement>('#status-strip'),
  refresh: required<HTMLButtonElement>('#refresh'),
  openGateway: required<HTMLButtonElement>('#open-gateway'),
}

buildNav()
parseHash()

el.refresh.addEventListener('click', () => void render())
el.openGateway.addEventListener('click', () => window.open('/api/health', '_blank', 'noopener'))
window.addEventListener('hashchange', () => {
  parseHash()
  void render()
})

void render()
startAutoRefresh()

function buildNav(): void {
  let currentGroup = ''
  for (const mod of MODULES) {
    if (mod.group !== currentGroup) {
      currentGroup = mod.group
      const header = document.createElement('div')
      header.className = 'nav-group'
      header.textContent = mod.group
      el.nav.append(header)
    }
    const btn = document.createElement('button')
    btn.type = 'button'
    btn.className = 'nav-btn'
    btn.dataset.module = mod.id
    btn.textContent = mod.label
    btn.addEventListener('click', () => navigate(mod.id))
    el.nav.append(btn)
  }
}

function navigate(id: ModuleId, params: Record<string, string> = {}): void {
  state.module = id
  state.params = params
  history.replaceState(null, '', `#${id}`)
  void render()
}

function makeContext(): ModuleContext {
  return {
    mount: el.content,
    setNotice,
    navigate,
    params: state.params,
  }
}

async function render(): Promise<void> {
  closeStream()
  setNotice('')
  const mod = MODULE_BY_ID.get(state.module) ?? overviewModule
  for (const btn of el.nav.querySelectorAll<HTMLElement>('.nav-btn')) {
    btn.classList.toggle('active', btn.dataset.module === mod.id)
  }
  el.title.textContent = mod.label
  el.content.innerHTML = '<div class="panel muted">Loading</div>'
  try {
    await updateStatus()
    await mod.render(makeContext())
  } catch (err) {
    el.content.innerHTML = `<div class="panel"><h2>Request failed</h2><p class="muted">${escapeHtml(messageOf(err))}</p></div>`
  }
}

// Refresh the current module on an interval without resetting nav/scroll, and
// only when the tab is visible and no stream is open, to avoid visual churn.
function startAutoRefresh(): void {
  state.timer = setInterval(() => {
    if (document.hidden || state.stream !== null) return
    void render()
  }, 10000)
}

async function updateStatus(): Promise<void> {
  const health = await gateway.json<Record<string, unknown>>('/health')
  const gatewayState = String(health.state ?? health.status ?? 'unknown')
  el.status.innerHTML = `
    <span class="pill ${gatewayState === 'running' ? 'ok' : 'warn'}">${escapeHtml(gatewayState)}</span>
    <div class="muted">gateway ${escapeHtml(String(health.status ?? 'unknown'))}</div>
  `
}

function parseHash(): void {
  const raw = location.hash.replace('#', '')
  state.module = MODULE_BY_ID.has(raw as ModuleId) ? (raw as ModuleId) : 'overview'
  state.params = {}
}

// ---------------------------------------------------------------------------
// Event streaming
// ---------------------------------------------------------------------------

function streamRun(runId: string): void {
  closeStream()
  const timeline = required<HTMLElement>('#timeline')
  timeline.innerHTML = ''
  state.stream = gateway.stream(`/runs/${encodeURIComponent(runId)}/stream`)
  state.stream.onmessage = (event) => appendStreamEvent(timeline, 'message', event.data)
  for (const type of [
    'run.state',
    'step.start',
    'step.complete',
    'step.error',
    'step.partial',
    'tool.call',
    'tool.result',
    'permission.denied',
    'run.completed',
    'run.failed',
    'run.cancelled',
    'permission.advisory',
  ]) {
    state.stream.addEventListener(type, (event) => appendStreamEvent(timeline, type, event.data))
  }
  state.stream.onerror = () => appendStreamEvent(timeline, 'stream.error', '{}')
}

function appendStreamEvent(timeline: HTMLElement, type: string, data: string): void {
  let payload: unknown
  try {
    payload = JSON.parse(data)
  } catch {
    payload = data
  }
  const row = document.createElement('div')
  row.className = `tl-row ${timelineClass(type)}`
  row.innerHTML = `
    <span class="tl-dot"></span>
    <div class="tl-body">
      <div class="tl-head"><strong>${escapeHtml(type)}</strong><span class="muted tl-time">${formatTime(Date.now())}</span></div>
      <pre class="tl-detail">${escapeHtml(typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2))}</pre>
    </div>`
  timeline.append(row)
  timeline.scrollTop = timeline.scrollHeight
}

function closeStream(): void {
  state.stream?.close()
  state.stream = null
}

// ---------------------------------------------------------------------------
// Shared rendering helpers
// ---------------------------------------------------------------------------

function runsTable(runs: readonly RunRow[], clickable = false): string {
  return `<div class="table-wrap"><table>
    <thead><tr><th>Run</th><th>Workflow</th><th>Status</th><th>Started</th></tr></thead>
    <tbody>${
      runs
        .map(
          (run) => `
      <tr ${clickable ? `data-run-id="${escapeAttr(run.runId)}"` : ''}>
        <td><strong>${escapeHtml(run.runId)}</strong></td>
        <td>${escapeHtml(run.pipelineId ?? run.workflowId ?? '-')}</td>
        <td><span class="pill ${statusClass(run.status)}">${escapeHtml(run.status)}</span></td>
        <td>${formatTime(run.startedAt)}</td>
      </tr>`,
        )
        .join('') || emptyRow(4, 'No runs recorded')
    }</tbody>
  </table></div>`
}

function artifactsList(runId: string, artifacts: Array<Record<string, any>>): string {
  if (artifacts.length === 0) return '<p class="muted">No artifacts</p>'
  return `<div class="table-wrap"><table><tbody>${artifacts
    .map(
      (a) => `
    <tr><td>${escapeHtml(a.name)}</td><td>${escapeHtml(a.mimeType)}</td><td>${Number(a.sizeBytes ?? 0).toLocaleString()} bytes</td><td><a href="/api/runs/${encodeURIComponent(runId)}/artifacts/${encodeURIComponent(a.artifactId)}">Download</a></td></tr>`,
    )
    .join('')}</tbody></table></div>`
}

function permissionsSummary(perms: PermissionView): string {
  const dims = perms.dimensions
  if (dims.length === 0 && perms.profile === undefined)
    return '<p class="muted">No declared permissions (default-deny).</p>'
  const chips = dims.map((d) => `<span class="pill perm">${escapeHtml(d)}</span>`).join('')
  const profile = perms.profile
    ? `<span class="pill">profile: ${escapeHtml(perms.profile)}</span>`
    : ''
  return `<div class="graph-perms">${chips}${profile}</div>`
}

// Best-effort permission dimension extraction from a workflow/manifest record.
// Only dimension labels and profile names are surfaced — never hosts, paths,
// tool ids, or secret values.
function collectPermissionDimensions(record: Record<string, any>): PermissionView {
  const perms =
    record.permissions ??
    record.skelm?.permissions ??
    record.defaultPermissions ??
    record.manifest?.permissions
  if (perms === undefined || perms === null || typeof perms !== 'object')
    return { dimensions: [] }
  const dimensions = Object.keys(perms).filter(
    (k) => k !== 'profile' && perms[k] !== undefined && perms[k] !== null,
  )
  const profile = typeof perms.profile === 'string' ? perms.profile : undefined
  return { dimensions, ...(profile !== undefined && { profile }) }
}

function metric(label: string, value: unknown, note: string): string {
  return `<div class="card metric"><span class="muted">${escapeHtml(label)}</span><strong>${escapeHtml(String(value))}</strong><span>${escapeHtml(note)}</span></div>`
}

function emptyRow(cols: number, message: string): string {
  return `<tr><td colspan="${cols}" class="muted">${escapeHtml(message)}</td></tr>`
}

function statusClass(status: string): string {
  if (status === 'completed' || status === 'running') return 'ok'
  if (status === 'failed' || status === 'cancelled') return 'bad'
  return 'warn'
}

function shortHash(value: unknown): string {
  if (typeof value !== 'string' || value === '') return '-'
  return value.length > 18 ? `${value.slice(0, 18)}…` : value
}

function setNotice(message: string): void {
  el.notice.textContent = message
  el.notice.classList.toggle('hidden', message === '')
}

function formatTime(value: unknown): string {
  if (value === undefined || value === null || value === '') return '-'
  const date = typeof value === 'number' ? new Date(value) : new Date(String(value))
  return Number.isNaN(date.getTime()) ? String(value) : date.toLocaleString()
}

function messageOf(err: unknown): string {
  return err instanceof Error ? err.message : String(err)
}

function escapeHtml(value: unknown): string {
  return String(value ?? '').replace(
    /[&<>"']/g,
    (char) =>
      ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      })[char] ?? char,
  )
}

function escapeAttr(value: unknown): string {
  return escapeHtml(value)
}

function required<T extends Element>(selector: string, root: ParentNode = document): T {
  const found = root.querySelector<T>(selector)
  if (found === null) throw new Error(`missing element: ${selector}`)
  return found
}

// ---------------------------------------------------------------------------
// Types for read-only gateway payloads
// ---------------------------------------------------------------------------

interface PermissionView {
  dimensions: string[]
  profile?: string
}

interface AgentPermissionsSummary {
  dimensions?: string[]
  profile?: string
  executableProfiles?: string[]
}

interface GraphNode {
  id: string
  kind?: string
  label?: string
  summary?: string
  permissions?: AgentPermissionsSummary
  codeOwned?: boolean
  children?: GraphNode[]
  data?: Record<string, unknown>
}

interface GraphResponse {
  id?: string
  version?: string
  kind?: string
  nodes?: GraphNode[]
  edges?: Array<{ from: string; to: string; kind?: string; label?: string }>
  meta?: Record<string, unknown>
}

interface GatewayEvent {
  type?: string
  event?: string
  stepId?: string
  toolName?: string
  timestamp?: number | string
  at?: number | string
  data?: unknown
  payload?: unknown
  detail?: unknown
  error?: unknown
}

interface TaskRecord {
  taskId: string
  workflowId?: string
  childRunId?: string
  parentRunId?: string
  status: string
  createdAt?: string
}

interface RunRefNode {
  runId: string
  pipelineId?: string
  status?: string
  taskId?: string
}

interface LineageNode extends RunRefNode {
  children?: LineageNode[]
}

interface LineageResult {
  runId: string
  ancestors?: RunRefNode[]
  descendants?: LineageNode[]
}
