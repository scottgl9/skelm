async function loadPackageDetail(ctx: ModuleContext, name: string): Promise<void> {
  ctx.params.name = name
  const detail = required<HTMLElement>('#pkg-detail', ctx.mount)
  detail.innerHTML = '<p class="muted">Loading package</p>'
  const pkg = await gateway.maybe<Record<string, any> | null>(
    `/v1/packages/${encodeURIComponent(name)}`,
    null,
  )
  if (pkg === null) {
    detail.innerHTML = `<p class="muted">No detail for ${escapeHtml(name)}</p>`
    return
  }
  const perms = collectPermissionDimensions(pkg.manifest ?? {})
  detail.innerHTML = `
    <h2>${escapeHtml(pkg.name)}</h2>
    <p class="muted">${escapeHtml(pkg.manifest?.description ?? '')}</p>
    <div class="grid two">
      ${metric('Versions', (pkg.versions ?? []).length, (pkg.versions ?? []).join(', ') || '-')}
      ${metric('Integrity', pkg.integrity ? 'present' : 'unverified', shortHash(pkg.integrity))}
    </div>
    <h3>Permissions Summary</h3>
    ${permissionsSummary(perms)}
    <h3>Manifest</h3>
    <pre>${escapeHtml(JSON.stringify(pkg.manifest ?? {}, null, 2))}</pre>
    <h3>Lockfile Entry</h3>
    <pre>${escapeHtml(JSON.stringify(pkg.lock ?? null, null, 2))}</pre>
  `
}

