// skelm operations dashboard — module-based app shell.
//
// All data is read through the same-origin `/api/*` proxy served by
// src/server.mts, which injects the gateway bearer token server-side. No
// gateway token is ever present in this browser code.

interface RunRow {
  runId: string
  pipelineId?: string
  workflowId?: string
  status: string
  startedAt?: number
}

interface ModuleContext {
  mount: HTMLElement
  setNotice(message: string): void
  navigate(id: ModuleId, params?: Record<string, string>): void
  params: Record<string, string>
}

interface DashboardModule {
  id: ModuleId
  label: string
  group: string
  render(ctx: ModuleContext): Promise<void>
}

type ModuleId =
  | 'overview'
  | 'workflows'
  | 'graph'
  | 'runs'
  | 'lineage'
  | 'packages'
  | 'integrations'
  | 'approvals'
  | 'schedules'
  | 'sessions'
  | 'runtime'
  | 'audit'
  | 'metrics'

interface AppState {
  module: ModuleId
  params: Record<string, string>
  stream: EventSource | null
  timer: ReturnType<typeof setInterval> | null
}

// ---------------------------------------------------------------------------
// Typed gateway proxy client. Every call is same-origin to `/api/*`; the local
// server.mts proxy adds the bearer token. This client never sees a token.
// ---------------------------------------------------------------------------

const gateway = {
  async json<T = unknown>(path: string, init: RequestInit = {}): Promise<T> {
    const res = await fetch(`/api${path}`, {
      ...init,
      headers: { 'content-type': 'application/json', ...(init.headers ?? {}) },
    })
    if (!res.ok) throw new Error(`${res.status} ${await res.text()}`)
    return (await res.json()) as T
  },
  async text(path: string): Promise<string> {
    const res = await fetch(`/api${path}`)
    if (!res.ok) throw new Error(`${res.status} ${await res.text()}`)
    return res.text()
  },
  async maybe<T>(path: string, fallback: T): Promise<T> {
    try {
      return await this.json<T>(path)
    } catch {
      return fallback
    }
  },
  stream(path: string): EventSource {
    return new EventSource(`/api${path}`)
  },
}

