async function loadLineage(ctx: ModuleContext, runId: string): Promise<void> {
  ctx.params.run = runId
  const input = ctx.mount.querySelector<HTMLInputElement>('#lineage-run')
  if (input) input.value = runId
  const tree = required<HTMLElement>('#lineage-tree', ctx.mount)
  tree.innerHTML = '<p class="muted">Loading lineage</p>'
  const lineage = await gateway.maybe<LineageResult | null>(
    `/v1/lineage/${encodeURIComponent(runId)}`,
    null,
  )
  if (lineage === null) {
    tree.innerHTML = `<p class="muted">No lineage for ${escapeHtml(runId)}</p>`
    return
  }
  const ancestors = (lineage.ancestors ?? [])
    .map((a) => `<div class="lineage-up">${runRef(a)}</div>`)
    .join('')
  const descendants = (lineage.descendants ?? []).map((d) => renderLineageNode(d)).join('')
  tree.innerHTML = `
    ${ancestors ? `<h3>Ancestors (nearest first)</h3>${ancestors}` : ''}
    <h3>Run</h3>
    <div class="lineage-self mono">${escapeHtml(lineage.runId)}</div>
    <h3>Descendants</h3>
    ${descendants || '<p class="muted">No child runs</p>'}
  `
}

function renderLineageNode(node: LineageNode): string {
  const children =
    node.children && node.children.length > 0
      ? `<div class="lineage-children">${node.children.map((c) => renderLineageNode(c)).join('')}</div>`
      : ''
  return `<div class="lineage-node">${runRef(node)}${children}</div>`
}

function runRef(ref: { runId: string; pipelineId?: string; status?: string }): string {
  return `<span class="mono">${escapeHtml(ref.runId)}</span> <span class="muted">${escapeHtml(ref.pipelineId ?? '')}</span> <span class="pill ${statusClass(ref.status ?? '')}">${escapeHtml(ref.status ?? '')}</span>`
}

