{
  "name": "@skelm/openclaw",
  "version": "0.1.0",
  "description": "Host-bridge package exposing OpenClaw-style tools over the skelm gateway HTTP API — run, inspect, cancel, and audit workflows from an OpenClaw-style host",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/openclaw"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "openclaw", "bridge", "host", "gateway", "tools"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "@skelm/core": "workspace:*",
    "@skelm/integration-sdk": "workspace:*"
  },
  "devDependencies": {
    "@skelm/core": "workspace:*",
    "@skelm/integration-sdk": "workspace:*",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.18"
  }
}
