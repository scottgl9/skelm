{
  "name": "@skelm/mcp-server",
  "version": "0.4.3",
  "description": "stdio MCP server that exposes skelm pipelines as tools",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "homepage": "https://skelm.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/skelm.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/skelm/issues"
  },
  "keywords": ["skelm", "mcp", "model-context-protocol", "workflow", "pipeline"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@skelm/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
