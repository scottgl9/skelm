{
  "name": "@skelm/pi",
  "version": "0.1.0",
  "description": "Pi coding-agent backend for skelm with full permission enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
